#
# Скопируй в .env и заполни. Файл .env в git НЕ попадает (см. .gitignore).

# ==== Shadowsocks (xray proxy) ====
SS_ADDRESS=your.server.ip.or.host
SS_PORT=53224
SS_METHOD=chacha20-ietf-poly1305
SS_PASSWORD=your-shadowsocks-password

# ==== FastAPI server ====
# Куда биндиться — по умолчанию 127.0.0.1:8787
# AV_BIND_HOST=0.0.0.0
# AV_BIND_PORT=8787

# Публичный origin сайта (нужен для canonical-URL, sitemap, robots).
# AV_SITE_URL=https://animeviev.example.com

# Название проекта в OpenGraph и JSON-LD.
# AV_SITE_NAME=AnimeViev

# CORS: список разрешённых origin'ов через запятую, либо "*" для wildcard.
# По умолчанию открыты локальные dev-origin'ы (127.0.0.1:5500/3000/8000/8787).
# AV_ALLOWED_ORIGINS=https://animeviev.example.com

# ==== AnimeSocial DB (читается из /animesocial-db.php по умолчанию) ====
# AV_DB_HOST=MySQL-8.0
# AV_DB_USER=root
# AV_DB_PASS=
# AV_DB_NAME=AnimeSocial
# AV_DB_PORT=3306
# AV_DB_PREFIX=Just

# Оверрайды для users-таблицы, если auto-detect выбирает не то.
# AV_USER_TABLE=Just_users
# AV_USER_ID_COL=id
# AV_USER_LOGIN_COL=login
# AV_USER_EMAIL_COL=email
# AV_USER_HASH_COL=password
# AV_USER_SALT_COL=salt
# AV_USER_NAME_COL=name
# AV_USER_STATUS_COL=status
# AV_USER_AVATAR_COL=avatar

# Какой верификатор пароля использовать.
# auto (default) — выбирается по форме хеша (bcrypt / sha256 / sha1 / md5+salt / dle).
# Иначе можно вручную: bcrypt | sha256 | sha1 | md5 | md5_salt | dle | plain | argon2
# AV_AUTH_VERIFIER=auto

# ==== Сессии и куки ====
# Время жизни login-сессии в днях. Дефолт 30.
# AV_SESSION_TTL_DAYS=30
# 1 — требовать HTTPS для login-cookie. Для прод — 1.
# AV_COOKIE_SECURE=0
# lax | strict | none. "none" требует Secure=1.
# AV_COOKIE_SAMESITE=lax

# ==== AnimeSocial (партнёр) ====
# Все ссылки на соцсеть собираются из animesocial.json. Переопределить
# можно только хост — пути (/login, /register, /uploads/accounts/...) зашиты
# в animesocial.json. Для локального OSPanel подставь https://animesocial.local
# AV_ANIMESOCIAL_SITE_URL=https://animesocial.online

# Legacy: прямо задать URL регистрации целиком (на случай, если у соцсети
# нестандартный маршрут). Если выставлено — перекрывает animesocial.json.
# AV_REGISTER_URL=https://animesocial.online/register

# Куда редиректить после успешного логина, если в URL не было ?next=.
# AV_LOGIN_LANDING=/

# ==== Legacy / xray ====
# AV_VPN_CONFIG=/etc/animeviev/vpn.json
